<script>
    let globalAccesToken = null;

    async function getSpotifyLoginURL() {
        return new Promise(function (resolve, reject) {
            $.ajax({
                type: 'GET',
                url: '/getSpotifyLoginURL'
            }).then((resp) => {
                resolve(resp)
            }).catch((err) => {
                reject(err)
            });
        })
    }

    async function openLoginPopup() {
        console.log('openLoginPopup')
        let AUTHORIZATION_URL = await getSpotifyLoginURL()
        popup = window.open(
            AUTHORIZATION_URL,
            'Login with Spotify',
            'width=800,height=600'
        );
    }

    $(document).ready(function () {

        initializeDatatable()

        setAccessToken()
        async function setAccessToken() {
            let accessToken = await getAccessToken()
            globalAccesToken = accessToken
        }

        async function getAccessToken() {
            return new Promise(function (resolve, reject) {
                $.ajax({
                    type: 'POST',
                    url: '/getAccessToken'
                }).then((resp) => {
                    resolve(resp)
                }).catch((err) => {
                    reject(err)
                });
            })
        }

        //if user hits enter key inside artist-search-input
        document.getElementById('artist-search-input').onkeypress = function(e){
            if (!e) e = window.event;
            var keyCode = e.code || e.key;
            if (keyCode == 'Enter'){
                // Enter pressed
                artistInputChanged()
                return false;
            }
        }

        async function openLoginPopup2() {
            console.log('openLoginPopup()')
            let AUTHORIZATION_URL = await getSpotifyLoginURL()
            popup = window.open(
                AUTHORIZATION_URL,
                'Login with Spotify',
                'width=800,height=600'
            )
        }



    });


    //wait x milliseconds (debug function)
    const delay = ms => new Promise(res => setTimeout(res, ms));

    let artistSearchInProgress = false;

    //artist search 
    async function spotifySearch(searchStr) {
        console.log(`spotifySearch(${searchStr})`)
        return new Promise(async function (resolve, reject) {
            $.ajax({
                url: `https://api.spotify.com/v1/search`,
                type: 'GET',
                contentType: 'application/json',
                headers: {
                    'Authorization': 'Bearer ' + globalAccesToken,
                },
                data: {
                    q: `${searchStr}`,
                    type: 'artist'
                }
            }).done(function callback(response) {
                resolve(response.artists.items)

            }).fail(function (error) {
                console.log("spotifySearch(): err=", error);
                reject(error)
            });
        })
    }

    //when search artist is clicked
    $('#artist-search-button').click(function () {
        //call function to handle changed artist-search-input
        artistInputChanged()
    });

    //when clear text input id is clicked
    $('#artist-search-clear').click(function () {
        //clear input value
        document.getElementById('artist-search-input').value = '';
        //call function to handle changed artist-search-input
        artistInputChanged()
    });

    // When artist input text field changes
    /*
    $("#artist-search-input").on("input", async function () {
        //call function to handle changed artist-search-input
        artistInputChanged()
    });
    */

    async function artistInputChanged() {
        try {
            let searchVal = $("#artist-search-input").val();
            searchVal = searchVal.trim();
            //verify search value is not blank
            if (searchVal != "" && searchVal != " " && searchVal != null && searchVal.length >= 2) {
                console.log('artist search input changed: ', searchVal)

                //display loading spinner
                $('#artist-search-results-loading').show()

                //get search results
                artistSearchInProgress = true
                let artistSearchResults = null;
                try {
                    artistSearchResults = await spotifySearch(searchVal)
                } catch (err) {
                    artistSearchInProgress = false;
                    //if search failed because of 429 (api rate limit exceeded)
                    if (err.status === 429) {
                        //open api rate limit popup message
                        displayRateLimitWarning()
                    }
                }
                console.log('artistSearchResults=', artistSearchResults)
                //hide loading spinner
                $('#artist-search-results-loading').hide()
                artistSearchInProgress = false;

                //clear search results html
                document.getElementById(`artist-search-results`).innerHTML = "";

                //if artistSearchResults is not null, display search results
                if (artistSearchResults) {
                    await displaySearchResults(artistSearchResults)
                }

            } else {
                //search box is empty so clear search results
                document.getElementById(`artist-search-results`).innerHTML = "";
                //hide clear earch button
                $('#artist-search-clear').hide()
            }
        } catch (err) {
            console.log('artistInputChanged() err=', err)

        }
    }

    async function displayRateLimitWarning() {
        //reveal html element
        $('#rate-limit-warning-popup').modal('toggle')
    }

    /*
            Pink Floyd 1
            updateArtistDisplay("http://www.classicrockhistory.com/wp-content/uploads/2015/10/81fvyZlrbAL._SL1300_-1024x1024.jpg", 'new')

            New Order
            updateArtistDisplay("https://img.discogs.com/9Qh48KAfjHx6iTzJuQ9F6NIresw=/fit-in/600x600/filters:strip_icc():format(jpeg):mode_rgb():quality(90)/discogs-images/R-8397631-1460829411-9240.jpeg.jpg", 'new')
            
    */

    async function displaySearchResults(artistData) {
        return new Promise(async function (resolve, reject) {
            //sort data via popularity
            artistData = artistData.sort((a, b) => parseFloat(a.popularity) - parseFloat(b.popularity));

            //create new html
            let newHTMLcontent = '';
            for (var i = 0; i < artistData.length; i++) {
                //get artist data
                let artistName = artistData[i].name
                let artistPopularity = artistData[i].popularity
                let artistId = artistData[i].id
                let artistImage = artistData[i].images[0] ? artistData[i].images[0].url : "../../static/assets/img/spotifyArtistUnknown.jpg"
                //construct html row
                let htmlRow = `
                <div class="row artist-row hover-mouse" >
                    <img src="${artistImage}"
                        class="img-responsive artist-results-album-art" alt="${artistName} image" width="50px" height="50px">
                    <div class="col">${artistName}</div>
                    <div class="col">Popularity: ${artistPopularity}</div>
                </div>
                `;
                //add html row to new html content
                newHTMLcontent = `${htmlRow}${newHTMLcontent}`
            }
            //display html
            document.getElementById(`artist-search-results`).innerHTML = `${newHTMLcontent}`;
            resolve()
        })
    }

    async function initializeDatatable() {
        var dataSet = [
            ["1", "song title 1", "FRANCHISE (feat Young)", "2 days ago", "3:22"],
            ["2", "song title 2", "FRANCHISE (feat Young)", "45 minuts ago", "1:22"],
            ["3", "song title 3", "FRANCHISE (feat Young)", "4 minutes ago", "0:21"],
            ["4", "song title 4", "FRANCHISE (feat Young)", "8 weeks ago", "11:21"],
        ];
        $('#tracklistTable').DataTable({
            data: dataSet,
            "searching": false,   // Search Box will Be Disabled
            "info": false,         // Will show "1 to n of n entries" Text at bottom
            "lengthChange": false, // Will Disabled Record number per page,
            "bPaginate": false, // Disable pagination "page 1 out of x"
            columns: [
                { title: "#" },
                { title: "TITLE" },
                { title: "ALBUM" },
                { title: "DATE ADDED" },
                { title: "TIME" }
            ]
        });
    }

    //call this function to update the artist display UI
    async function updateArtistDisplay(imgURL, artistName) {
        return new Promise(async function (resolve, reject) {
            //get colors for image
            let imageColors = await getImageColors(imgURL)
            console.log(imageColors)
            //update image html element
            document.getElementsByClassName('album-art')[0].src = imgURL;
            //get light vibrant hex
            let VibrantHex = imageColors['Vibrant'].hex
            //get 50% lighter version of Vibrant
            let brighterVibrant = ColorLuminance(`${VibrantHex.replace('#', '')}`, 0.5);
            //update header css gradient 
            document.getElementsByClassName('header-row-results')[0].style.background = `linear-gradient(0deg, rgb(18,18,18) -86%, ${brighterVibrant})`;
            //get 60% darker version of Vibrant
            let darkerVibrant = ColorLuminance(`${VibrantHex.replace('#', '')}`, -0.6);
            //update body css gradient
            document.getElementsByClassName('body-row')[0].style.background = `linear-gradient(180deg, ${darkerVibrant}, rgb(18,18,18))`;

            resolve("")
        })
    }

    //lighten or darken a hex color
    function ColorLuminance(hex, lum) {

        // validate hex string
        hex = String(hex).replace(/[^0-9a-f]/gi, '');
        if (hex.length < 6) {
            hex = hex[0] + hex[0] + hex[1] + hex[1] + hex[2] + hex[2];
        }
        lum = lum || 0;

        // convert to decimal and change luminosity
        var rgb = "#", c, i;
        for (i = 0; i < 3; i++) {
            c = parseInt(hex.substr(i * 2, 2), 16);
            c = Math.round(Math.min(Math.max(0, c + (c * lum)), 255)).toString(16);
            rgb += ("00" + c).substr(c.length);
        }

        return rgb;
    }

    //send image url to backend, get back color swatches (name, rgb, hex)
    async function getImageColors(imgURL) {
        return new Promise(function (resolve, reject) {
            $.ajax({
                type: 'POST',
                url: '/getImageColors',
                data: {
                    imgURL: imgURL
                },
            }).then((resp) => {


                //for each color, create div and display on page
                let htmlStr = ``;
                for (const [key, value] of Object.entries(resp)) {
                    htmlStr = `${htmlStr} <br> <div style="background:${value.hex}; width=200px;height=200px;">${key} ${value.hex}</div>`
                }
                document.getElementById('debug-color-box').innerHTML = htmlStr;

                //calculate 50% darker version of LightVibrant
                //let darkerLightVibrant = ColorLuminance(`${resp['LightVibrant'].hex.replace('#','')}`, -0.5);


                resolve(resp)
            }).catch((err) => {
                console.log('getImageColors() err = ', err)
                reject(err)
            });
        });
    }
</script>

